# ==================== 基础配置 ====================
PORT=5000
NODE_ENV=production

# ==================== MongoDB 配置 ====================
MONGODB_URI=mongodb://localhost:27017/usdchou
MONGODB_DB=usdchou
MONGODB_HOST=localhost
MONGODB_PORT=27017

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== JWT 配置 ====================
# ⚠️ 重要：请修改为随机字符串（至少32个字符）
# 可以使用这个命令生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars-long
JWT_EXPIRE=7d

# ==================== TRON 区块链配置 ====================
# 从 https://trongrid.io 注册获取免费 API Key
TRON_API_KEY=your-trongrid-api-key-here
TRON_NETWORK=mainnet  # mainnet(主网) 或 shasta(测试网)

# ==================== 审计服务配置（可选）====================
AUDIT_SERVER_URL=http://localhost:5001
AUDIT_SECRET_KEY=another-random-secret-key-for-audit

# ==================== 日志配置 ====================
LOG_LEVEL=info  # debug, info, warn, error
LOG_FILE_PATH=./logs

# ==================== 其他配置 ====================
# CORS 允许的域名（多个用逗号分隔）
CORS_ORIGINS=*

# 最大上传文件大小
MAX_FILE_SIZE=10mb
