    if (response && response.data) {
      chainGroupInfo.value = response.data
      console.log('🐉 接龙群信息:', chainGroupInfo.value)
      
      // 即使 isChainGroup 是 false，只要有 memberInfo 就显示
      if (chainGroupInfo.value.memberInfo) {
        // 如果没有 canGrabAfter，根据 joinedAt 计算
        if (!chainGroupInfo.value.memberInfo.canGrabAfter && chainGroupInfo.value.memberInfo.joinedAt) {
          const joinedAt = new Date(chainGroupInfo.value.memberInfo.joinedAt)
          const waitHours = chainGroupInfo.value.waitHours || 3
          const canGrabAfter = new Date(joinedAt.getTime() + waitHours * 60 * 60 * 1000)
          chainGroupInfo.value.memberInfo.canGrabAfter = canGrabAfter.toISOString()
          console.log('⏰ 计算 canGrabAfter:', canGrabAfter)
        }
        
        // 如果还在等待期，启动倒计时
        if (chainGroupInfo.value.memberInfo.canGrabAfter && !chainGroupInfo.value.memberInfo.kickedOut) {
          const canGrabAfter = new Date(chainGroupInfo.value.memberInfo.canGrabAfter)
          const now = new Date()
          
          if (now < canGrabAfter) {
            startChainCountdown(canGrabAfter)
          } else {
            chainWaitCountdown.value = '可以抢红包了！'
          }
        }
      }
    }
  } catch (error) {
    //  静默处理：非接龙群或接口不存在时不报错
    // 400/404 表示这不是接龙群，正常情况
    const status = error.response?.status
    if (status === 400 || status === 404) {
      console.log('ℹ️ 当前群不是接龙群，跳过加载')
    } else {
      console.warn('⚠️ 加载接龙群信息失败:', error.message)
    }
    chainGroupInfo.value = null
  }
}

// 启动接龙群等待倒计时
const startChainCountdown = (targetTime) => {
  if (chainCountdownTimer) {
    clearInterval(chainCountdownTimer)
  }
  
  const updateCountdown = () => {
    const now = new Date()
    const diff = targetTime - now
    
    if (diff <= 0) {
      chainWaitCountdown.value = '可以抢红包了！'
      clearInterval(chainCountdownTimer)
      return
    }
    
    const hours = Math.floor(diff / (1000 * 60 * 60))
    const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))
    const seconds = Math.floor((diff % (1000 * 60)) / 1000)
    
    chainWaitCountdown.value = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`
  }
  
  updateCountdown()
  chainCountdownTimer = setInterval(updateCountdown, 1000)
}

