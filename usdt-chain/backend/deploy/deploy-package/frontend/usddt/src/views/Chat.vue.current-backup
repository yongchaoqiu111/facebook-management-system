// 添加消息（带智能去重）
// 生成头像背景色
const getAvatarColor = (name) => {
  const colors = [
    '#1890ff', '#52c41a', '#faad14', '#f5222d', '#722ed1', 
    '#eb2f96', '#13c2c2', '#fa8c16', '#a0d911', '#2f54eb'
  ]
  let hash = 0
  for (let i = 0; i < name.length; i++) {
    hash = name.charCodeAt(i) + ((hash << 5) - hash)
  }
  return colors[Math.abs(hash) % colors.length]
}

// 添加消息到列表（带去重）
const addMessage = (newMessage) => {
  console.log('📥 添加消息:', newMessage)
  
  // ✅ 针对红包消息的特殊去重逻辑
  if (newMessage.type === 'redPacket') {
    const exists = messages.value.some(msg => 
      msg.type === 'redPacket' && 
      msg.redPacketId === newMessage.redPacketId
    )
    
    console.log('红包消息是否已存在:', exists)
    
    if (!exists) {
      console.log('✅ 添加红包消息:', newMessage.redPacketId)
      
      // ✅ 使用展开运算符创建新数组，强制触发Vue响应式
      messages.value = [...messages.value, newMessage]
      
      console.log('📊 当前消息数量:', messages.value.length)
      
      // 保存到本地存储
      if (currentContact.value) {
        saveChatToLocalStorage(currentContact.value.id, messages.value)
