// 发送消息
const sendMessage = async () => {
  if (!messageInput.value.trim() || !currentContact.value) return
  
  const now = new Date()
  const time = now.getHours() + ':' + (now.getMinutes()< 10 ? '0' : '') + now.getMinutes()
  const content = messageInput.value.trim()
  const clientMsgId = Date.now().toString() + Math.random().toString(36).substr(2, 9)
  
  try {
    const currentUserId = localStorage.getItem('userId')
    
    // 判断是私聊还是群聊
    if (currentContact.value.isGroup) {
      // 发送群聊消息
      sendGroupMessage({
        groupId: currentContact.value.id,
        content: content,
        type: 'text',
        clientMsgId: clientMsgId,
        senderId: currentUserId
      })
    } else {
      // 发送私聊消息
      sendPrivateMessage({
        receiverId: currentContact.value.id,
        content: content,
        type: 'text',
        clientMsgId: clientMsgId,
        senderId: currentUserId
      })
    }
    
    // ✅ 本地乐观更新 - 立即显示消息
    const message = {
      id: clientMsgId,
      type: 'sent',
      content: content,
      time: time,
      clientMsgId: clientMsgId,
      senderId: currentUserId,
      receiverId: currentContact.value.isGroup ? null : currentContact.value.id,
      groupId: currentContact.value.isGroup ? currentContact.value.id : null,
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
      isSelf: true,
      sender: currentUser.value || { username: 'Me' }
    }
    
    console.log('📤 发送消息，添加到列表:', message)
    addMessage(message)
    messageInput.value = ''
  } catch (error) {
    console.error('发送消息失败:', error)
    messageInput.value = ''
    alert('发送消息失败，请稍后重试')
  }
}

