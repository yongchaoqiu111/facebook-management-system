      console.log('⚠️ 红包消息已存在，跳过:', newMessage.redPacketId)
      return false
    }
  } else {
    // 普通消息的去重逻辑
    const exists = messages.value.some(msg => 
      (msg.id === newMessage.id && msg.content === newMessage.content) ||
      (msg.clientMsgId === newMessage.clientMsgId && newMessage.clientMsgId)
    )
    
    console.log('普通消息是否已存在:', exists)
    
    if (!exists) {
      console.log('✅ 添加新消息:', newMessage.id, newMessage.content)
      
      // ✅ 使用展开运算符创建新数组，强制触发Vue响应式
      messages.value = [...messages.value, newMessage]
      
      console.log('📊 当前消息数量:', messages.value.length)
      
      // 保存到本地存储
      if (currentContact.value) {
        saveChatToLocalStorage(currentContact.value.id, messages.value)
      }
      scrollToBottom()
      return true
    } else {
      console.log('⚠️ 消息已存在，跳过:', newMessage.id)
      return false
    }
  }
}

// 设置Socket事件监听
const setupSocketListeners = () => {
  const currentUserId = localStorage.getItem('userId')
  
  // 监听私聊消息
  onPrivateMessage((data) => {
    console.log('🔔 收到私聊消息:', data)
    
    const now = new Date()
    const time = now.getHours() + ':' + (now.getMinutes()< 10 ? '0' : '') + now.getMinutes()
    
    const currentUserId = localStorage.getItem('userId')
    // 🐉 获取当前用户的 ObjectId（优先从 userObjectId，其次从 user 对象中解析）
    let currentUserObjectId = localStorage.getItem('userObjectId')
    if (!currentUserObjectId) {
      try {
        const userStr = localStorage.getItem('user')
        if (userStr) {
          const userObj = JSON.parse(userStr)
          currentUserObjectId = userObj._id || userObj.id
        }
      } catch (e) {
        console.warn('⚠️ 无法解析 user 对象:', e)
      }
    }
    
    console.group('🔔 收到 Socket 消息')
    console.log('原始消息:', data)
    console.log('发送者对象:', data.sender)
    console.log('接收者对象:', data.receiver)
    
    // 获取消息中的业务ID和ObjectId
    const senderUserId = typeof data.sender === 'object' ? data.sender.userId : null
    const senderObjectId = typeof data.sender === 'object' ? data.sender._id : data.sender
    const receiverUserId = typeof data.receiver === 'object' ? data.receiver.userId : null
    const receiverObjectId = typeof data.receiver === 'object' ? data.receiver._id : data.receiver
    
    console.log('发送者业务ID:', senderUserId)
    console.log('发送者ObjectId:', senderObjectId)
    console.log('接收者业务ID:', receiverUserId)
    console.log('接收者ObjectId:', receiverObjectId)
    console.log('当前用户ID:', currentUserId)
    console.log('当前用户ObjectId:', currentUserObjectId)
    console.log('聊天对方ID:', currentContact.value?.userId || currentContact.value?.id)
    
    // 🐉 调试：打印完整的 sender 和 receiver 对象
    console.log('🔍 完整 sender 对象:', JSON.stringify(data.sender))
    console.log('🔍 完整 receiver 对象:', JSON.stringify(data.receiver))
    
    // 🐉 判断是否是当前私聊的消息（简化逻辑：只要聊天对象匹配即可）
