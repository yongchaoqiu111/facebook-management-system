      String(receiverUserId) === String(currentUserId) ||
      String(senderObjectId) === String(currentUserId) ||
      String(receiverObjectId) === String(currentUserId) ||
      String(senderObjectId) === String(currentUserObjectId) || // 🐉 新增：用 ObjectId 匹配
      String(receiverObjectId) === String(currentUserObjectId) // 🐉 新增：用 ObjectId 匹配
    
    // 私聊：只要聊天对象匹配且当前用户参与，就显示
