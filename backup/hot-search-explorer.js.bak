}
function extractPotentialKeywords(news) {
    // 简单的关键词提取逻辑，实际项目中可以使用更复杂的NLP方法
    const keywords = new Set();
    news.forEach(item => {
        // 提取可能的热搜词
        const words = item.split(/[\s，。！？；："'()\[\]{}]+/).filter(word => word.length >= 2);
        words.forEach(word => keywords.add(word));
    });
    return Array.from(keywords).slice(0, 10); // 只取前10个可能的关键词
}
function updateKeywords(existingKeywords, newKeywords) {
    let updated = false;
    const maxKeywords = 100;
    newKeywords.forEach(keyword => {
        if (!existingKeywords.includes(keyword) && existingKeywords.length < maxKeywords) {
            existingKeywords.push(keyword);
            updated = true;
        }
        else if (!existingKeywords.includes(keyword) && existingKeywords.length >= maxKeywords) {
            // 替换最老的关键词
            existingKeywords.shift();
            existingKeywords.push(keyword);
            updated = true;
        }
    });
    if (updated) {
        writeKeywords(existingKeywords);
    }
    return updated;
}
async function exploreHotSearch(input) {
    log('开始热搜词探索任务');
    try {
        // 1. 读取关键词列表
        const keywords = readKeywords();
        // 2. 随机选择一个关键词
        const selectedKeyword = selectRandomKeyword(keywords);
        log(`选择的关键词: ${selectedKeyword}`);
        // 3. Google搜索
        const news = await searchGoogle(selectedKeyword);
        log(`找到 ${news.length} 条相关新闻`);
        if (news.length === 0) {
            return {
                code: 0,
                data: {
                    searchKeyword: selectedKeyword,
                    newsCount: 0,
                    generatedPost: '未找到相关新闻',
                    updatedKeywords: false
                }
            };
        }
        // 4. 保存新闻
        const newsContent = saveNews(news, selectedKeyword);
        // 5. 生成Facebook帖子
        const post = await generateFacebookPost(newsContent);
        // 6. 保存帖子
        savePost(post);
        // 7. 提取潜在的新热搜词
        const potentialKeywords = extractPotentialKeywords(news);
        // 8. 更新关键词列表
        const updated = updateKeywords(keywords, potentialKeywords);
        log('热搜词探索任务完成');
        return {
            code: 0,
            data: {
                searchKeyword: selectedKeyword,
                newsCount: news.length,
                generatedPost: post,
                updatedKeywords: updated
            }
        };
    }
    catch (error) {
        log(`任务执行失败: ${error instanceof Error ? error.message : String(error)}`);
        return {
            code: 500,
            data: {
                searchKeyword: '',
                newsCount: 0,
                generatedPost: `任务执行失败: ${error instanceof Error ? error.message : String(error)}`,
                updatedKeywords: false
            }
        };
    }
}
