# App
APP_PORT=3000

# Weibo
WEIBO_DEFAULT_ACCOUNT_ID=default
WEIBO_PERSONA_PROFILE_FILE=data/persona_profile.txt
WEIBO_PASSWORD_LOGIN_ENABLED=false
WEIBO_LOGIN_USERNAME=
WEIBO_PASSWORD_FILE=data/weibo_password.txt

# Weibo Follow Interest Workflow
WEIBO_FOLLOW_ENABLED=true
WEIBO_FOLLOW_CRON=30 9 * * *
WEIBO_FOLLOW_TIMEZONE=Asia/Shanghai
WEIBO_FOLLOW_KEYWORD_FILE=data/follow_keywords.txt
WEIBO_FOLLOW_PER_KEYWORD_MAX_FOLLOWS=3
WEIBO_FOLLOW_LOGIN_TIMEOUT_SECONDS=240

# Weibo Smart Follow Workflow (客户可调)
WEIBO_SMART_MAX_TOTAL_POSTS=10
WEIBO_SMART_PER_KEYWORD_MAX_POSTS=5
WEIBO_SMART_MAX_LIKES=2
WEIBO_SMART_MAX_FOLLOWS=1
WEIBO_SMART_MAX_COMMENTS=1
WEIBO_SMART_COMMENT_TEXT=观点很有启发，感谢分享。
WEIBO_SMART_INSIGHTS_FILE=data/tmp/smart_follow_insights.json

# Weibo Daily Publish Workflow
WEIBO_DAILY_WORKFLOW_ENABLED=true
WEIBO_DAILY_WORKFLOW_CRON=0 8 * * *
WEIBO_DAILY_WORKFLOW_TIMEZONE=Asia/Shanghai
WEIBO_DAILY_WORKFLOW_QUERY=AI
WEIBO_DAILY_WORKFLOW_SIZE=5
WEIBO_DAILY_WORKFLOW_STYLE=严肃
WEIBO_DAILY_WORKFLOW_LOGIN_TIMEOUT_SECONDS=240

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_RETRY_DELAY_MAX_MS=2000
REDIS_MAX_RETRIES_PER_REQUEST=3

# DingTalk
# 留空表示不发送钉钉告警
DINGTALK_WEBHOOK=

# LLM (OpenAI-compatible)
LLM_BASE_URL=
LLM_API_KEY=
LLM_API_KEY_FILE=data/llm_api_key.txt
LLM_MODEL=Qwen3-235B-A22B
LLM_TIMEOUT_MS=30000
# 也支持复用主骨架同名变量（任选其一）:
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# Skill mock behavior (开发环境调试用)
SKILL_MOCK_FAILURE_RATE=0.1
SKILL_MOCK_MIN_DELAY_MS=200
SKILL_MOCK_MAX_DELAY_MS=1000
